{
  "name": "next-advanced-sitemap",
  "version": "1.2.4",
  "type": "module",
  "description": "Advanced sitemap generator for Next.js. Powerful support for Google Images, Video, News, and Hreflang (multilingual). Type-safe and built for App Router.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup src/index.ts --watch",
    "build": "tsup",
    "test": "vitest run",
    "size": "size-limit",
    "prepublishOnly": "npm run test && npm run build"
  },
  "keywords": [
    "nextjs",
    "sitemap",
    "seo",
    "google-images",
    "google-video",
    "google-news",
    "hreflang",
    "multilingual",
    "typescript",
    "app-router"
  ],
  "author": "fomadev",
  "license": "FomaDev Public License",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fomadev/next-advanced-sitemap.git"
  },
  "bugs": {
    "url": "https://github.com/fomadev/next-advanced-sitemap/issues"
  },
  "homepage": "https://github.com/fomadev/next-advanced-sitemap#readme",
  "devDependencies": {
    "@size-limit/preset-small-lib": "^11.1.4",
    "@types/node": "^26.1.0",
    "size-limit": "^11.1.4",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3",
    "vitest": "^1.4.0"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "4 KB"
    },
    {
      "path": "dist/index.cjs",
      "limit": "4 KB"
    }
  ],
  "peerDependencies": {
    "next": ">=13.0.0",
    "react": ">=18.0.0"
  }
}